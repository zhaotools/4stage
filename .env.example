# Local live-data updates only. Never commit a real token.
TUSHARE_TOKEN=

# Default requires no token and updates the configured ETFs with live, forward-adjusted data.
DATA_PROVIDER=eastmoney

# Set to true after index_weight and stock_basic permissions are confirmed.
INCLUDE_HS300=false

# Conservative default stays below common per-minute API limits.
TUSHARE_REQUEST_INTERVAL_MS=1250
